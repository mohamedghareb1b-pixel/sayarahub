# ============================================
# SayaraHub — متغيرات البيئة (Environment Variables)
# انسخ هذا الملف باسم .env وعبّي القيم الحقيقية
# cp .env.example .env
# ============================================

# ---------- قاعدة البيانات (Postgres / Supabase) ----------
# لو شغّال محلي بـ Docker Postgres عادي:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/app_db"
#
# لو هتستخدم Supabase (الأسهل، فيها Postgres مُدار مجاناً):
# روح لـ Project Settings > Database > Connection string > URI
# واختار "Connection pooling" لو هتشغل السيرفر على منصة serverless زي Vercel
DATABASE_URL=""

# ---------- WhatsApp Cloud API (Meta) ----------
# لازم تعمل حساب Meta for Developers وتنشئ App من نوع Business
# https://developers.facebook.com/apps
# 1) WHATSAPP_ACCESS_TOKEN: من صفحة الـ App > WhatsApp > API Setup
#    (فيه Temporary token صالح 24 ساعة، وفيه Permanent token عن طريق System User)
WHATSAPP_ACCESS_TOKEN=""

# 2) WHATSAPP_PHONE_ID: رقم الـ Phone Number ID (مش رقم التليفون نفسه)
#    موجود في نفس صفحة API Setup تحت "From"
WHATSAPP_PHONE_ID=""

# 3) WHATSAPP_VERIFY_TOKEN: أنت اللي تخترعه (أي نص عشوائي قوي)
#    وتحطه في نفس القيمة في:
#    Meta App > WhatsApp > Configuration > Webhook > Verify Token
WHATSAPP_VERIFY_TOKEN="اكتب-توكن-عشوائي-قوي-هنا"

# ---------- Gemini AI (لتحليل رسائل الطلبات بالذكاء الاصطناعي) ----------
# اختياري: لو سيبته فاضي هيشتغل الـ parser الاحتياطي (rule-based) بدل الـ AI
# احصل عليه من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ---------- تشغيل عام ----------
NODE_ENV="development"

# ---------- حماية الـ Cron Jobs (مقترح إضافته للكود، غير موجود حالياً) ----------
# سر خاص لحماية /api/cron/[job] من الاستدعاء العشوائي من أي حد
# لازم تضاف يدوياً في الكود (route.ts) — شوف قسم "التوصيات الأمنية" في الـ README
CRON_SECRET=""

# ---------- حماية لوحة الإدارة (مقترح إضافته للكود، غير موجود حالياً) ----------
# يوزر وباسورد بسيطين لحماية /admin عن طريق Basic Auth أو middleware
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
